{
  "name": "@tannus/react-native-chatbot-next",
  "version": "0.1.0-beta.10",
  "description": "Modern TypeScript rewrite of react-native-chatbot with API compatibility",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format cjs,esm",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo 'add eslint config'",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-reanimated": ">=3"
  },
  "peerDependenciesMeta": {
    "react-native-reanimated": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "tsup": "^8.0.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
